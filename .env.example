# Notion API token used by the webhook handler.
# Webhook capabilities are NOT auto-authenticated, so this is required.
# Use a personal access token (acts as you) or an internal integration token
# (acts as a bot — must be connected to the Blog and Newsletter databases).
# Needs capabilities: read_content, insert_content, insert_property, update_content.
#
# Set it for the deployed worker with:
#   ntn workers env set NOTION_API_TOKEN=ntn_...
NOTION_API_TOKEN=ntn_xxx
